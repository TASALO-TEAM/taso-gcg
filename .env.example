# Token del bot, obtenido de @BotFather
TELEGRAM_TOKEN=

# IDs de Telegram de los dueños del bot (separados por coma o espacio).
# Tienen acceso total: chats oficiales, broadcast, federación, stats.
SUDO_USERS=

# (Opcional) Chat/canal donde el bot avisa cuando arranca/se detiene.
LOG_CHAT_ID=

# (Opcional) Restringir qué módulos se cargan. Vacío = cargar todos los de modules/.
# Ejemplo: LOAD=admin,bans,warns
LOAD=
NO_LOAD=

# Comportamiento por defecto (se puede sobreescribir por chat con /setwarnlimit, etc.)
DEFAULT_WARN_LIMIT=3
DEFAULT_FLOOD_LIMIT=0
ADMIN_CACHE_TTL_SECONDS=300

# (Opcional) IA vía Groq: traducción de RSS (/settranslate) y contexto de
# moderación. Si se deja vacío, esas funciones se desactivan solas y el resto
# del bot sigue funcionando igual.
# Acepta una o varias keys separadas por coma (rotación round-robin: si una
# cuenta pega el límite de rate, se prueba la siguiente antes de rendirse).
# Ejemplo con varias: GROQ_API_KEY=gsk_primera...,gsk_segunda...
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
